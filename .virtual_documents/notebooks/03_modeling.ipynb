df_pro.head()


# Scaled Data

train_dataset = pd.read_csv("../data/scaled_train_data.csv")
test_dataset = pd.read_csv("../data/scaled_test_data.csv")

X_train = train_dataset.drop(columns=["Price","Unnamed: 0"])
y_train = train_dataset["Price"]

X_test = test_dataset.drop(columns=["Price","Unnamed: 0"])
y_test = test_dataset["Price"]


X_train.info()


y_train.shape


X_test.shape





lin_model = LinearRegression()

lin_model.fit(X_train,y_train)








alphas = [0.001, 0.05,0.1, 0.5, 1,2,5,8,10,15,20,25,50,55, 60,65,70,80,90,100]

lasso_model = LassoCV(alphas=alphas, max_iter=5000)

lasso_model.fit(X_train, y_train)


print("Best alpha : ", lasso_model.alpha_)


y_lasso_pred = lasso_model.predict(X_test)

print("MSE: ", mean_squared_error(y_test, y_lasso_pred))
print("R2: ", r2_score(y_test, y_lasso_pred))


ridge_model = RidgeCV(alphas=alphas)

ridge_model.fit(X_train, y_train)


print("Best alpha : ", ridge_model.alpha_)


y_ridge_pred = ridge_model.predict(X_test)

print("MSE: ", mean_squared_error(y_test, y_ridge_pred))
print("R2: ", r2_score(y_test, y_ridge_pred))





from sklearn.neighbors import KNeighborsRegressor

#Base model
KNN_model = KNeighborsRegressor()

KNN_model.fit(X_train, y_train)


y_knn_pred = KNN_model.predict(X_test)

print("MSE: ", mean_squared_error(y_test, y_knn_pred))
print("R2: ", r2_score(y_test, y_knn_pred))


param_grid={"n_neighbors": [17,19,21,23,25,27]}

knn_grid = GridSearchCV(
    estimator=KNeighborsRegressor(),
    param_grid=param_grid,
    cv=5
)

knn_grid.fit(X_train,y_train)


print("Best parameter : ", knn_grid.best_params_)


y_knn_grid_pred = knn_grid.predict(X_test)

print("MSE: ", mean_squared_error(y_test, y_knn_grid_pred))
print("R2: ", r2_score(y_test, y_knn_grid_pred))





